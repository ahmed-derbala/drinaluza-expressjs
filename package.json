{
  "name": "drinaluza-server",
  "version": "1.3.47",
  "main": "src/main.js",
  "description": "Drinaluza, business manager (backend server)",
  "author": "Ahmed Derbala <derbala.ahmed531992@gmail.com>",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmed-derbala/drinaluza-expressjs"
  },
  "keywords": [
    "drinaluza"
  ],
  "imports": {
    "#error": "./src/core/error/index.js",
    "#log": "./src/core/log/index.js",
    "#helpers": "./src/core/helpers/index.js",
    "#mongodb/*": "./src/core/db/mongodb/*",
    "#products/*": "./src/features/products/*",
    "#feed/*": "./src/features/feed/*",
    "#orders/*": "./src/features/orders/*",
    "#reviews/*": "./src/features/reviews/*",
    "#users/*": "./src/features/users/*",
    "#businesses/*": "./src/features/businesses/*",
    "#dashboard/*": "./src/features/dashboard/*",
    "#config": "./src/config/index.js",
    "#address": "./src/core/db/mongodb/shared-schemas/address.schema.js",
    "#location": "./src/core/db/mongodb/shared-schemas/location.schema.js",
    "#media": "./src/core/db/mongodb/shared-schemas/media.schema.js",
    "#multilang": "./src/core/db/mongodb/shared-schemas/multi-lang.schema.js",
    "#state": "./src/core/db/mongodb/shared-schemas/state.schema.js",
    "#slug": "./src/core/db/mongodb/slug-plugin.js",
    "#files": "./src/core/files/*",
    "#auth": "./src/core/auth/index.js",
    "#shared-schemas": "./src/core/db/mongodb/shared-schemas/*",
    "#core": "./src/core/index.js",
    "#core/*": "./src/core/*"
  },
  "scripts": {
    "smenu": "NODE_ENV=local node src/core/scripts/smenu.js",
    "smenu:prod": "NODE_ENV=production node src/core/scripts/smenu.js",
    "config:new-prod": "cp src/config/default.config.js src/config/production.config.js",
    "config:prod": "cp -n src/config/default.config.js src/config/production.config.js",
    "ver": "npm version patch --no-git-tag-version",
    "build:prod": "npm run config:new-prod && npm run clean:prod",
    "build:run": "npm run build && npm run start:prod",
    "frl": "cp src/config/default.config.js src/config/local.config.js && npm run i && npm run start:local",
    "frp": "npm run config:new-prod && npm run clean:prod && npm run start:prod-pm2-monit",
    "start": "node src/main.js",
    "start:prod": "NODE_ENV=production node src/main.js",
    "start:prod-pm2": "npm run i:prod && NODE_ENV=production pm2 start --name drinaluza src/main.js -i max --node-args='--max-old-space-size=8192' -f",
    "start:prod-pm2-monit": "npm run start:prod-pm2 && pm2 monit",
    "start:local": "NODE_ENV=local node --watch-path=./src src/main.js",
    "dev": "npm run start:local",
    "dev:prod": "NODE_ENV=production node --watch-path=./src src/main.js",
    "debug": "NODE_ENV=local NODE_DEBUG=module node --trace-warnings --stack-trace-limit=100 --watch-path=./src src/main.js",
    "start:local-pm2": "pm2 start src/config/pm2.config.js --env local && pm2 monit",
    "start:dev": "NODE_ENV=development node --watch-path=./src --max-old-space-size=8192 src/main.js",
    "reload": "pm2 reload drinaluza",
    "stop": "pm2 stop all",
    "delete": "pm2 delete all",
    "monit": "pm2 monit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "push": "npm run format && git add . && git commit -m",
    "postpush": "git push && npm run ver",
    "pushd": "npm run push",
    "pull": "git pull origin main && npm run i && npm run start:local",
    "i": "npm i",
    "i:prod": "NODE_ENV=production npm ci --omit=dev",
    "clean": "npm run clean:only && npm run start:local",
    "clean:prod": "rm -rf node_modules  && npm run i:prod",
    "clean:only": "rm -rf package-lock.json node_modules && npm run i",
    "code": "windsurf . && npm run start:local",
    "backup": "rm -rf backups/* && mkdir backups -p && cp package.json backups/package.json.backup && cp package-lock.json backups/package-lock.json.backup 2>/dev/null; true && mv node_modules backups/node_modules.backup 2>/dev/null; true",
    "update": "npm run backup && npm run ncu && npm run clean:only",
    "restore": "cp backups/package.json.backup package.json && cp backups/package-lock.json.backup package-lock.json && mv backups/node_modules.backup node_modules && npm run start:local",
    "ncu": "npx npm-check-updates --peer -u"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "cli-color": "^2.0.4",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "expo-server-sdk": "^6.1.0",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.5.2",
    "express-useragent": "^2.2.1",
    "express-validator": "^7.3.2",
    "express-winston": "^4.2.0",
    "glob": "^13.0.6",
    "helmet": "^8.2.0",
    "inquirer": "^14.0.2",
    "ip": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.4",
    "mongoose-unique-validator": "^6.1.1",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "multer-storage-cloudinary": "^4.0.0",
    "prettier": "^3.9.5",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-mongodb": "^7.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0"
  }
}
